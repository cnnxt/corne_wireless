/*
 * Corne wireless (Typeractive) — full keymap backup
 * Transcribed key-by-key from the live board via ZMK Studio + owner confirmation.
 *
 * Layers: 0 base · 1 sym_num · 2 mac nav · 3 windows nav (+ 2 reserved for Studio headroom)
 *
 * Notes:
 *  - This board is ZMK Studio-managed; edits made in Studio live in the keyboard's
 *    settings and override this file unless you do "Restore Stock Settings".
 *  - mac nav volume uses C_VOL_UP/DN (Studio displayed "Keyboard Volume"); functionally
 *    identical for volume control. Adjust if you want the exact keyboard-page code.
 *  - base right-pinky Ctrl/AltG (bottom-right two keys) are best-read; owner noted the
 *    right-pinky Ctrl isn't used in practice.
 */

#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>

/ {
    keymap {
        compatible = "zmk,keymap";

        base {
            display-name = "base";
            bindings = <
&mt LS(LA(LCTRL)) ESC  &kp Q     &kp W  &kp E     &kp R     &kp T          &kp Y     &kp U     &kp I      &kp O    &kp P                 &kp FSLH
&mt LA(LGUI) TAB       &kp A     &kp S  &lt 1 D   &lt 3 F   &kp G          &kp H     &kp J     &kp K      &kp L    &kp SQT               &kp MINUS
&kp LSHFT              &lt 2 Z   &kp X  &kp C     &kp V     &kp B          &kp N     &kp M     &kp COMMA  &kp DOT  &mt LS(RS(LCTRL)) N9  &mt RALT N0
                                        &mt LCTRL EQUAL  &kp LGUI  &lt 1 SPACE    &kp BSPC  &lt 2 RET  &mt RALT SEMI
            >;
        };

        sym_num {
            display-name = "sym_num";
            bindings = <
&kp LS(BSLH)    &kp LS(N1)  &kp LS(N2)    &kp LS(N3)  &kp LS(N5)  &kp LS(N4)        &kp KP_PLUS   &kp N1  &kp N2  &kp N3  &kp LS(LBKT)  &kp LS(RBKT)
&kp LS(GRAVE)   &kp LS(N6)  &kp LS(BSLH)  &kp LS(N7)  &kp LS(N8)  &kp LS(EQUAL)     &kp KP_MINUS  &kp N4  &kp N5  &kp N6  &kp LBKT      &kp RBKT
&kp LS(LG(N5))  &kp END     &kp HOME      &kp PG_UP   &kp PG_DN   &kp LS(LG(N4))    &kp EQUAL     &kp N7  &kp N8  &kp N9  &kp LS(N9)    &kp LS(N0)
                                          &kp LC(UP)  &kp LC(DOWN)  &trans          &trans  &kp N0  &trans
            >;
        };

        mac_nav {
            display-name = "mac nav";
            bindings = <
&trans        &trans  &trans      &bt BT_PRV    &bt BT_NXT  &trans        &trans  &trans     &trans    &trans    &trans  &kp LC(UP)
&kp C_BRI_UP  &trans  &trans      &kp C_VOL_UP  &trans      &trans        &trans  &kp BSPC   &kp UP    &kp DEL   &trans  &kp LC(DOWN)
&kp C_BRI_DN  &trans  &kp C_PREV  &kp C_VOL_DN  &kp C_NEXT  &trans        &trans  &kp LEFT   &kp DOWN  &kp RIGHT &trans  &trans
                                  &trans  &trans  &kp C_PP                &kp LS(LGUI)  &trans  &trans
            >;
        };

        windows_nav {
            display-name = "windows nav";
            bindings = <
&trans  &trans  &trans  &trans  &trans  &trans        &trans  &trans    &trans    &trans     &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans        &trans  &trans    &kp UP    &trans     &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans        &trans  &kp LEFT  &kp DOWN  &kp RIGHT  &trans  &trans
                        &trans  &trans  &trans        &kp LGUI  &trans  &trans
            >;
        };

        // Reserved empty layers give ZMK Studio room to add more layers later
        // without a reflash. Ignored in normal builds.
        extra_1 {
            status = "reserved";
        };

        extra_2 {
            status = "reserved";
        };
    };
};
